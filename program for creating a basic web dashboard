</head>

<body>

<h1>🌦 Weather Dashboard</h1>

<div class="grid">

<div class="card">
<div class="label">Temperature</div>
<div class="value" id="temp">-- °C</div>
<canvas id="tempChart"></canvas>
</div>

<div class="card">
<div class="label">Humidity</div>
<div class="value" id="hum">-- %</div>
<canvas id="humChart"></canvas>
</div>

<div class="card">
<div class="label">Pressure</div>
<div class="value" id="pres">--</div>
<canvas id="presChart"></canvas>
</div>

<div class="card">
<div class="label">AQI</div>
<div class="value" id="aqi">--</div>
<canvas id="aqiChart"></canvas>
</div>

<div class="card">
<div class="label">Rain</div>
<div class="value" id="rain">--</div>
<canvas id="rainChart"></canvas>
</div>

</div>

<script>
let labels=[];
let tempData=[], humData=[], presData=[], aqiData=[], rainData=[];

function createChart(id, color, dataArr){
  return new Chart(document.getElementById(id), {
    type: 'line',
    data: {
      labels: labels,
      datasets: [{
        data: dataArr,
        borderColor: color,
        borderWidth: 2,
        fill: false,
        tension: 0   // 🔥 STRAIGHT LINES (IMPORTANT)
      }]
    },
    options: {
      plugins: { legend: { display:false }},
      scales: {
        x: { display:false },
        y: { display:false }
      }
    }
  });
}

let tempChart = createChart('tempChart','#ef4444',tempData);
let humChart  = createChart('humChart','#3b82f6',humData);
let presChart = createChart('presChart','#22c55e',presData);
let aqiChart  = createChart('aqiChart','#a855f7',aqiData);
let rainChart = createChart('rainChart','#f59e0b',rainData);

setInterval(() => {
  fetch('/data')
  .then(res => res.json())
  .then(data => {

    document.getElementById('temp').innerHTML = data.temp + " °C";
    document.getElementById('hum').innerHTML = data.hum + " %";
    document.getElementById('pres').innerHTML = data.pres;
    document.getElementById('aqi').innerHTML = data.aqi;
    document.getElementById('rain').innerHTML = data.rain;

    let time = new Date().toLocaleTimeString();
    labels.push(time);

    tempData.push(data.temp);
    humData.push(data.hum);
    presData.push(data.pres);
    aqiData.push(data.aqi);
    rainData.push(data.rain);

    if(labels.length > 20){
      labels.shift();
      tempData.shift();
      humData.shift();
      presData.shift();
      aqiData.shift();
      rainData.shift();
    }

    tempChart.update();
    humChart.update();
    presChart.update();
    aqiChart.update();
    rainChart.update();

  });
}, 3000);
