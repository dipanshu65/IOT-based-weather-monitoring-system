server.send(200, "text/html", page);
}
// 🔥 DATA API
void sendData() {
  String json = "{";
  json += "\"temp\":" + String(temp) + ",";
  json += "\"hum\":" + String(hum) + ",";
  json += "\"pres\":" + String(pres) + ",";
  json += "\"aqi\":" + String(aqi) + ",";
  json += "\"rain\":" + String(rain);
  json += "}";

  server.send(200, "application/json", json);
}

// ⚙️ SETUP
void setup() {
  Serial.begin(115200);
  Serial2.begin(9600, SERIAL_8N1, 16, 17);

  WiFi.begin(ssid, password);

  int timeout = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
    timeout++;

    if (timeout > 300) {
      Serial.println("\nWiFi Failed!");
      return;
    }
  }

  Serial.println("\nWiFi Connected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  server.on("/", handleRoot);
  server.on("/data", sendData);

  server.begin();
  Serial.println("Server started!");
}

// 🔁 LOOP
void loop() {
  if (Serial2.available()) {
    data = Serial2.readStringUntil('\n');
    data.trim();

    data.replace("DATA: ", "");

    int i1 = data.indexOf(',');
    int i2 = data.indexOf(',', i1 + 1);
    int i3 = data.indexOf(',', i2 + 1);
    int i4 = data.indexOf(',', i3 + 1);

    temp = data.substring(0, i1).toFloat();
    hum  = data.substring(i1 + 1, i2).toFloat();
    pres = data.substring(i2 + 1, i3).toFloat();
    aqi  = data.substring(i3 + 1, i4).toInt();
    rain = data.substring(i4 + 1).toInt();
  }

  server.handleClient();
}
