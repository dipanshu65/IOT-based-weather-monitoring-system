#include <WiFi.h>
#include <WebServer.h>

const char* ssid = "DIPANSHU";
const char* password = "123456789";

WebServer server(80);

String data = "";

float temp, hum, pres;
int aqi, rain;

// 🔧 Forward declaration
void sendData();

// 🌐 WEB PAGE
void handleRoot() {
String page = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Weather Pro Dashboard</title>

