#include <Wire.h>
#include <Adafruit_BMP085.h>
#include <Adafruit_Sensor.h>
#include <DHT.h>
#include <DHT_U.h>

// -------- PINS --------
#define Rain_SensorPin 3
#define Air_SensorPin A3
#define Temp_Hum_SensorPin 2

DHT_Unified dht(Temp_Hum_SensorPin, DHT11);
Adafruit_BMP085 bmp;

// -------- VARIABLES --------
float temperature = 0, humidity = 0, pressure = 0;
int AQI = 0, rainfall = 0;

unsigned long lastSensorUpdate = 0;

// -------- READ SENSORS --------
void read_sensor_data() {
  sensors_event_t event;

  // Temperature
  dht.temperature().getEvent(&event);
  if (!isnan(event.temperature)) {
    temperature = event.temperature;
  }

  // Humidity
  dht.humidity().getEvent(&event);
  if (!isnan(event.relative_humidity)) {
    humidity = event.relative_humidity;
  }

  // Pressure (in hPa)
  pressure = bmp.readPressure() / 100.0;

  // Air Quality
  int mq135Raw = analogRead(Air_SensorPin);
  AQI = map(mq135Raw, 0, 1023, 0, 300);

  // Rain sensor
  rainfall = (digitalRead(Rain_SensorPin) == HIGH) ? 0 : 1;
}

// -------- SETUP --------
void setup() {
  Serial.begin(115200);    // Debug (PC)
  Serial1.begin(9600);     // ESP32 communication

  Wire.begin();

  pinMode(Rain_SensorPin, INPUT);
  pinMode(Air_SensorPin, INPUT);

  dht.begin();

  if (!bmp.begin()) {
    Serial.println("BMP180 not found!");
  }

  Serial.println("System Started");
}

// -------- LOOP --------
void loop() {
  if (millis() - lastSensorUpdate >= 1000) {
    lastSensorUpdate = millis();

    read_sensor_data();

    // 🔍 Debug output (Serial Monitor)
    Serial.print("DATA: ");
    Serial.print(temperature); Serial.print(",");
    Serial.print(humidity); Serial.print(",");
    Serial.print(pressure); Serial.print(",");
    Serial.print(AQI); Serial.print(",");
    Serial.println(rainfall);

    // 🚀 SEND TO ESP32 (IMPORTANT FIX)
    Serial1.print(temperature); Serial1.print(",");
    Serial1.print(humidity); Serial1.print(",");
    Serial1.print(pressure); Serial1.print(",");
    Serial1.print(AQI); Serial1.print(",");
    Serial1.println(rainfall);  // MUST end with newline
  }
}
